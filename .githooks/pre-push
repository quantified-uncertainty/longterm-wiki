#!/usr/bin/env bash
#
# Pre-push hook — runs CI-blocking checks before allowing push.
# Activate with: git config core.hooksPath .githooks
#
# To bypass (emergencies only): git push --no-verify
#

set -euo pipefail

echo ""
echo "Running pre-push gate checks..."
echo ""

pnpm crux validate gate

# After gate passes, run agent checklist auto-verify and completion check.
# Blocks push if checklist exists but is <10% complete (session skipped workflow).
# Advisory warning at <25%. No checklist = no block (quick fix sessions).
echo ""
pnpm crux agent-checklist pre-push-check

# Exit code from gate determines whether push proceeds
