{
  "name": "longterm-wiki",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter longterm-next dev",
    "build": "pnpm --filter longterm-next build",
    "test": "pnpm --filter longterm-next test && pnpm --filter discord-bot test && pnpm --filter wiki-server test && vitest run --config crux/vitest.config.ts",
    "test:crux": "vitest run --config crux/vitest.config.ts",
    "build-data:content": "pnpm --filter longterm-next run sync:data:content",
    "build-data:quick": "pnpm --filter longterm-next run sync:data:content",
    "validate": "DOTENV_CONFIG_QUIET=true NODE_USE_ENV_PROXY=1 node --import tsx/esm crux/crux.mjs validate",
    "crux": "DOTENV_CONFIG_QUIET=true NODE_USE_ENV_PROXY=1 node --import tsx/esm crux/crux.mjs",
    "typecheck:tooling": "npx tsx crux/validate/validate-crux-tsc.ts",
    "setup": "bash scripts/setup.sh",
    "setup:quick": "bash scripts/setup.sh --quick",
    "setup:check": "bash scripts/setup.sh --check",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "dotenv": "^17.2.4",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.7.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@mendable/firecrawl-js": "^1.15.5"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "hono": "^4.12.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "tsx": "^4.19.0",
    "unified": "^11.0.5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "dompurify": ">=3.3.2",
      "immutable": ">=4.3.8"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
