# apps/web environment variables
# Copy to .env and fill in values for local development.
# The workspace-root .env is loaded automatically by next.config.ts,
# so you can also put these vars there.

# GitHub OAuth App credentials (required for /internal/* access control)
# Register at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Set "Authorization callback URL" to: https://your-domain/api/auth/callback/github
# Leave blank for open (unauthenticated) access in local dev.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random secret for signing next-auth JWTs (required in production)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of this deployment (required in production by next-auth)
NEXTAUTH_URL=https://your-domain.com

# Comma-separated list of GitHub usernames that may access /internal/* routes
# Example: ADMIN_GITHUB_USERS=alice,bob,charlie
ADMIN_GITHUB_USERS=
