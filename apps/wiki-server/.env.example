# wiki-server environment variables
# Copy to .env and fill in values for local development.

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/longterm_wiki

# Optional: Separate connection string for migrations. Use when the main
# DATABASE_URL role has a server-side statement_timeout that blocks DDL,
# or when you need to bypass pgbouncer for ALTER TABLE / CREATE INDEX.
# Falls back to DATABASE_URL if not set.
# DATABASE_MIGRATION_URL=postgresql://migration_user:password@localhost:5432/longterm_wiki

# API key for authenticating requests. If not set, auth is skipped (dev mode).
LONGTERMWIKI_SERVER_API_KEY=your-api-key-here

# Optional: HTTP port (default: 3100)
PORT=3100
